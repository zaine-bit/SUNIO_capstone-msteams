<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.msteams.controller.RegisterController">
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="Create an Account" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <TextField fx:id="nameField" promptText="Full name" prefWidth="240"/>
    <TextField fx:id="emailField" promptText="Email" prefWidth="240"/>
    <PasswordField fx:id="passwordField" promptText="Password" prefWidth="240"/>
    <ComboBox fx:id="roleComboBox" promptText="Role" prefWidth="240"/>

    <Button text="Register" onAction="#handleRegister" prefWidth="120"/>
    <Button text="Already have an account? Log In" onAction="#goToLogin"/>

    <Label fx:id="statusLabel" wrapText="true"/>
</VBox>
