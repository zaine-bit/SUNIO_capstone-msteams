<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.msteams.controller.SubmissionsController">
    <top>
        <VBox spacing="4">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Label fx:id="assignmentTitleLabel" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
        </VBox>
    </top>
    <center>
        <ListView fx:id="submissionListView">
            <BorderPane.margin>
                <Insets top="0" right="20" bottom="10" left="20"/>
            </BorderPane.margin>
        </ListView>
    </center>
    <bottom>
        <VBox spacing="10">
            <padding>
                <Insets top="0" right="20" bottom="20" left="20"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Grade for selected submission:"/>
                <TextField fx:id="gradeField" prefWidth="80"/>
                <Button text="Save Grade" onAction="#handleSaveGrade"/>
            </HBox>
            <Label fx:id="statusLabel" wrapText="true"/>
            <Button text="Back" onAction="#goBack"/>
        </VBox>
    </bottom>
</BorderPane>
